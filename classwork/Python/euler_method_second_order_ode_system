    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Define the parameters\n",
    "k = 1.0        # Constant in the equation (e.g., spring constant)\n",
    "h_values = [0.01, 0.02, 0.03, 0.05, 0.1, 0.2, 0.3, 0.5]\n",
    "x_start = 0    # Start of the interval\n",
    "x_end = 10     # End of the interval\n",
    "y_0 = 1.0      # Initial condition for y\n",
    "v_0 = 0.0      # Initial condition for dy/dx\n",
    "\n",
    "# Prepare the plot\n",
    "plt.figure(figsize=(12, 8))\n",
    "\n",
    "# Loop through each step size\n",
    "for h in h_values:\n",
    "    # Create arrays to store x, y, and v values\n",
    "    x_values = np.arange(x_start, x_end + h, h)\n",
    "    y_values = np.zeros(len(x_values))\n",
    "    v_values = np.zeros(len(x_values))\n",
    "    \n",
    "    # Set initial conditions\n",
    "    y_values[0] = y_0\n",
    "    v_values[0] = v_0\n",
    "    \n",
    "    # Euler's Method loop\n",
    "    for i in range(1, len(x_values)):\n",
    "        x_n = x_values[i - 1]\n",
    "        y_n = y_values[i - 1]\n",
    "        v_n = v_values[i - 1]    \n",
    "        \n",
    "        # Update equations\n",
    "        y_values[i] = y_n + h * v_n\n",
    "        v_values[i] = v_n + h * (-k * y_n)\n",
    "        \n",
    "    # Plot the results for the current h\n",
    "    plt.plot(x_values, y_values, label=f'h = {h}')\n",
    "\n",
    "# Format the plot\n",
    "plt.xlabel('x')\n",
    "plt.ylabel('Position y(x)')\n",
    "plt.title('Euler\\'s Method Solutions for d²y/dx² = -ky across varying step sizes (h)')\n",
    "plt.legend(loc='upper left', bbox_to_anchor=(1, 1))\n",
    "plt.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]

   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Define the interval and number of points\n",
    "a = 0\n",
    "b = 2 * np.pi\n",
    "N = 25  # We use a relatively small N so the differences are visually noticeable\n",
    "x = np.linspace(a, b, N)\n",
    "\n",
    "# Step size\n",
    "h = (b - a) / (N - 1)\n",
    "\n",
    "# Define our function\n",
    "def f(x):\n",
    "    return np.sin(x)\n",
    "\n",
    "# True derivative for comparison\n",
    "true_df = np.cos(x)\n",
    "\n",
    "# Central Difference Approximation for the derivative\n",
    "central_diff = (f(x + h) - f(x - h)) / (2 * h)\n",
    "\n",
    "# Forward Difference Approximation\n",
    "### YOUR CODE HERE ###\n",
    "forward_diff = (f(x + h) - f(x)) / h\n",
    "\n",
    "# Backward Difference Approximation\n",
    "### YOUR CODE HERE ###\n",
    "backward_diff = (f(x) - f(x - h)) / h\n",
    "\n",
    "# Plot the approximation and the true derivative\n",
    "fig, axs = plt.subplots(2, 2, figsize=(12, 8))\n",
    "fig.suptitle('Approximating Derivative of f(x) = sin(x) with Finite Differences', fontsize=16)\n",
    "\n",
    "# 1. True Derivative Plot\n",
    "axs[0, 0].plot(x, true_df, 'k-', linewidth=2, label='True: cos(x)')\n",
    "axs[0, 0].set_title('True Derivative')\n",
    "axs[0, 0].legend()\n",
    "axs[0, 0].grid(True)\n",
    "\n",
    "# 2. Forward Difference Plot\n",
    "axs[0, 1].plot(x, true_df, 'k--', alpha=0.5, label='True: cos(x)')\n",
    "axs[0, 1].plot(x, forward_diff, 'r.-', label='Forward Diff')\n",
    "axs[0, 1].set_title('Forward Difference')\n",
    "axs[0, 1].legend()\n",
    "axs[0, 1].grid(True)\n",
    "\n",
    "# 3. Backward Difference Plot\n",
    "axs[1, 0].plot(x, true_df, 'k--', alpha=0.5, label='True: cos(x)')\n",
    "axs[1, 0].plot(x, backward_diff, 'b.-', label='Backward Diff')\n",
    "axs[1, 0].set_title('Backward Difference')\n",
    "axs[1, 0].legend()\n",
    "axs[1, 0].grid(True)\n",
    "\n",
    "# 4. Central Difference Plot\n",
    "axs[1, 1].plot(x, true_df, 'k--', alpha=0.5, label='True: cos(x)')\n",
    "axs[1, 1].plot(x, central_diff, 'g.-', label='Central Diff')\n",
    "axs[1, 1].set_title('Central Difference')\n",
    "axs[1, 1].legend()\n",
    "axs[1, 1].grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]

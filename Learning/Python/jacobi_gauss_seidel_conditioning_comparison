    "import numpy as np\n",
    "import time\n",
    "\n",
    "def is_diagonally_dominant(A):\n",
    "    \"\"\"Checks if a matrix is diagonally dominant per slide 28.\"\"\"\n",
    "    D = np.abs(np.diag(A))\n",
    "    S = np.sum(np.abs(A), axis=1) - D\n",
    "    # A is diagonally dominant if |Aii| >= sum(|Aij|) for all i\n",
    "    return np.all(D >= S)\n",
    "\n",
    "def jacobi(A, b, tol=1e-10, max_iter=10000):\n",
    "    \"\"\"Jacobi iteration method.\"\"\"\n",
    "    n = len(b)\n",
    "    x = np.zeros(n)\n",
    "    start_time = time.time()\n",
    "    for it in range(max_iter):\n",
    "        x_new = np.zeros(n)\n",
    "        for i in range(n):\n",
    "            # Sum of A[i,j]*x[j] for j != i\n",
    "            s = sum(A[i, j] * x[j] for j in range(n) if i != j)\n",
    "            x_new[i] = (b[i] - s) / A[i, i]\n",
    "        \n",
    "        # Check for convergence\n",
    "        if np.linalg.norm(x_new - x, ord=np.inf) < tol:\n",
    "            return x_new, it + 1, time.time() - start_time\n",
    "        x = x_new\n",
    "    return x, max_iter, time.time() - start_time\n",
    "\n",
    "def gauss_seidel(A, b, tol=1e-10, max_iter=10000):\n",
    "    \"\"\"Gauss-Seidel iteration method.\"\"\"\n",
    "    n = len(b)\n",
    "    x = np.zeros(n)\n",
    "    start_time = time.time()\n",
    "    for it in range(max_iter):\n",
    "        x_old = x.copy()\n",
    "        for i in range(n):\n",
    "            # Uses the most updated values of x as they become available\n",
    "            s1 = sum(A[i, j] * x[j] for j in range(i))\n",
    "            s2 = sum(A[i, j] * x_old[j] for j in range(i + 1, n))\n",
    "            x[i] = (b[i] - s1 - s2) / A[i, i]\n",
    "            \n",
    "        if np.linalg.norm(x - x_old, ord=np.inf) < tol:\n",
    "            return x, it + 1, time.time() - start_time\n",
    "    return x, max_iter, time.time() - start_time\n",
    "\n",
    "# --- Setup for Challenges ---\n",
    "\n",
    "# Challenge Part A: 5x5 System\n",
    "A_a = np.array([\n",
    "    [0.582745, 0.48, 0.10, 0.0, 0.0],\n",
    "    [0.48, 1.044129, 0.46, 0.10, 0.0],\n",
    "    [0.10, 0.46, 1.10431, 0.44, 0.10],\n",
    "    [0.0, 0.10, 0.44, 0.963889, 0.42],\n",
    "    [0.0, 0.0, 0.10, 0.42, 0.522565]\n",
    "], dtype=float)\n",
    "b_a = np.array([1.162745, 2.084129, 2.20431, 1.923889, 1.042565], dtype=float)\n",
    "\n",
    "# Challenge Part B & C: Ill-Conditioned System\n",
    "A_bc = np.array([[1.0, 1.0], [1.0, 1.0001]])\n",
    "b_b = np.array([1.0, 1.0])\n",
    "b_c = np.array([1.0, 1.0001])\n",
    "\n",
    "# --- Executing Solvers ---\n",
    "\n",
    "def run_test(name, A, b):\n",
    "    print(f\"\\n--- {name} ---\")\n",
    "    print(f\"Diagonally Dominant: {is_diagonally_dominant(A)}\")\n",
    "    print(f\"Condition Number: {np.linalg.cond(A):.2f}\")\n",
    "    \n",
    "    x_j, it_j, t_j = jacobi(A, b)\n",
    "    x_gs, it_gs, t_gs = gauss_seidel(A, b)\n",
    "    \n",
    "    print(f\"Jacobi:       x = {x_j}, iterations = {it_j}, time = {t_j:.6f}s\")\n",
    "    print(f\"Gauss-Seidel: x = {x_gs}, iterations = {it_gs}, time = {t_gs:.6f}s\")\n",
    "\n",
    "run_test(\"Coding Challenge Part A\", A_a, b_a)\n",
    "run_test(\"Coding Challenge Part B\", A_bc, b_b)\n",
    "run_test(\"Coding Challenge Part C\", A_bc, b_c)"
   ]
